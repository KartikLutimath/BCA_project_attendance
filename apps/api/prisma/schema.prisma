// prisma/schema.prisma
// SmartAttendance AI — Full Database Schema (Phase 2)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

model User {
  id           String    @id @default(cuid())
  fullName     String
  email        String    @unique
  passwordHash String
  role         Role      @default(STUDENT)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  student       Student?
  teacher       Teacher?
  refreshTokens RefreshToken[]

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// INSTITUTION STRUCTURE
// ─────────────────────────────────────────────────────────────────────────────

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now())

  subjects Subject[]
  sections Section[]
  teachers Teacher[]
}

model Subject {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  departmentId String
  credits      Int      @default(3)
  createdAt    DateTime @default(now())

  department Department  @relation(fields: [departmentId], references: [id])
  timetables Timetable[]

  @@index([departmentId])
}

model Section {
  id           String   @id @default(cuid())
  name         String // e.g. "6CSE-A"
  semester     Int
  departmentId String
  academicYear String // e.g. "2024-25"
  createdAt    DateTime @default(now())

  department Department  @relation(fields: [departmentId], references: [id])
  students   Student[]
  timetables Timetable[]

  @@index([departmentId])
  @@index([semester])
}

model Classroom {
  id        String   @id @default(cuid())
  name      String   @unique // "Block-A Room 101"
  building  String
  latitude  Float
  longitude Float
  radius    Float    @default(200) // metres — geofence radius
  createdAt DateTime @default(now())

  timetables Timetable[]
}

// ─────────────────────────────────────────────────────────────────────────────
// PEOPLE
// ─────────────────────────────────────────────────────────────────────────────

model Student {
  id         String   @id @default(cuid())
  userId     String   @unique
  rollNumber String   @unique
  sectionId  String
  enrolledAt DateTime @default(now())

  user           User           @relation(fields: [userId], references: [id])
  section        Section        @relation(fields: [sectionId], references: [id])
  attendance     Attendance[]
  faceDescriptor FaceDescriptor?
  leaveRequests  LeaveRequest[]

  @@index([rollNumber])
  @@index([sectionId])
}

model Teacher {
  id           String   @id @default(cuid())
  userId       String   @unique
  employeeId   String   @unique
  departmentId String
  designation  String   @default("Assistant Professor")
  joinedAt     DateTime @default(now())

  user           User          @relation(fields: [userId], references: [id])
  department     Department    @relation(fields: [departmentId], references: [id])
  timetables     Timetable[]
  leaveApprovals LeaveRequest[] @relation("ApprovedBy")

  @@index([employeeId])
  @@index([departmentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// TIMETABLE ENGINE
// ─────────────────────────────────────────────────────────────────────────────

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model Timetable {
  id            String    @id @default(cuid())
  teacherId     String
  subjectId     String
  sectionId     String
  classroomId   String
  dayOfWeek     DayOfWeek
  startTime     String // "09:00"
  endTime       String // "10:00"
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  teacher   Teacher   @relation(fields: [teacherId], references: [id])
  subject   Subject   @relation(fields: [subjectId], references: [id])
  section   Section   @relation(fields: [sectionId], references: [id])
  classroom Classroom @relation(fields: [classroomId], references: [id])
  attendance Attendance[]

  @@index([sectionId, dayOfWeek])
  @@index([teacherId, dayOfWeek])
  @@index([classroomId, dayOfWeek])
  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────────────────────────────────────

enum AttendanceStatus {
  PENDING
  APPROVED
  REJECTED
  FINALIZED
}

model Attendance {
  id               String           @id @default(cuid())
  studentId        String
  timetableId      String
  date             DateTime         @db.Date
  status           AttendanceStatus @default(PENDING)
  isVerified       Boolean          @default(false)

  // Biometric & geo metadata
  faceVerified     Boolean          @default(false)
  faceConfidence   Float?
  geofenceVerified Boolean          @default(false)
  latitude         Float?
  longitude        Float?
  markedAt         DateTime         @default(now())
  ipAddress        String?

  student   Student   @relation(fields: [studentId], references: [id])
  timetable Timetable @relation(fields: [timetableId], references: [id])
  logs      AttendanceLog[]

  // Prevent duplicate marking
  @@unique([studentId, timetableId, date])
  @@index([studentId, date])
  @@index([timetableId, date])
  @@index([date])
}

model AttendanceLog {
  id             String           @id @default(cuid())
  attendanceId   String
  changedBy      String // userId of teacher/admin who changed it
  previousStatus AttendanceStatus
  newStatus      AttendanceStatus
  reason         String?
  changedAt      DateTime         @default(now())

  attendance Attendance @relation(fields: [attendanceId], references: [id])

  @@index([attendanceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FACE RECOGNITION
// ─────────────────────────────────────────────────────────────────────────────

model FaceDescriptor {
  id          String   @id @default(cuid())
  studentId   String   @unique
  descriptor  Json // Float32Array[128] stored as JSON
  sampleCount Int      @default(1)
  enrolledAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// LEAVE REQUESTS
// ─────────────────────────────────────────────────────────────────────────────

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id           String      @id @default(cuid())
  studentId    String
  approvedById String?
  fromDate     DateTime    @db.Date
  toDate       DateTime    @db.Date
  reason       String
  status       LeaveStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  student    Student  @relation(fields: [studentId], references: [id])
  approvedBy Teacher? @relation("ApprovedBy", fields: [approvedById], references: [id])

  @@index([studentId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}
